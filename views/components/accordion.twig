{% if items|length > 0 %}
    <div class="accordion-site accordion w-100" id="accordionComponent">
        {% for key, item in items %}
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                            data-bs-target="#collapse{{ key }}" aria-expanded="false" aria-controls="collapse{{ key }}">
                        {{ item.title }}
                    </button>
                </h2>
                <div id="collapse{{ key }}" class="accordion-collapse collapse" data-bs-parent="#accordionComponent">
                    <div class="accordion-body">
                        <p class="m-0">
                            {{ item.content|nl2br }}
                        </p>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}